# =============================================================================
# AI Platform — Environment Variables
# Copy this file to .env and fill in real values before running.
# =============================================================================

# --- PostgreSQL (used by Docker Compose and the backend service) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=aiplatform

# --- Backend (Express API — backend/.env or Docker env) ---
# Full connection string built from the Postgres vars above
DATABASE_URL=postgresql://admin:secret@db:5432/aiplatform
# Stripe secret key — must be a test key (sk_test_...)
STRIPE_SECRET_KEY=sk_test_xxxx
# Port the Express server listens on
PORT=4000

# --- Web (Next.js — web/.env.local or Docker env) ---
# NEXT_PUBLIC_ prefix means this is inlined into the browser bundle at build time.
# Use the publicly-accessible URL so the browser can reach the Express API.
# In Docker: the api service exposes port 4000 on the host.
# In local dev (without Docker): http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Internal URL used by Next.js server-side code inside Docker to reach Express.
# Not needed for local dev outside Docker.
BACKEND_URL=http://api:4000
